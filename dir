class EntryInfo(NamedTuple):
	path: str
	name: str
	file_stat: os.stat_result
	is_hidden: bool
	is_directory: bool
	is_executable: bool
	file_type: str
	link_target: Optional[str]
	link_is_broken: bool
	link_target_is_directory: bool
	link_target_is_executable: bool


class OperandResult(NamedTuple):
	paths: list[str]
	used_pattern: bool
	had_error: bool


