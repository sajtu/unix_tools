	print(
		f'Directory: "{format_directory_path(directory)}"'
	)
	print()


def print_entry_section(
	directory: str,
	entries: list[EntryInfo],
	sort_by_time: bool,
	reverse: bool,
	show_stats: bool,
) -> list[EntryInfo]:
	print_section_header(directory)

	sorted_entries = sort_entries(
		entries,
		sort_by_time,
		reverse,
	)

	if not sorted_entries:
		print("** EMPTY DIRECTORY **")

		if show_stats:
			print_report("Section Statistics", sorted_entries)

		return sorted_entries

	print_table(sorted_entries)

	if show_stats:
		print_report("Section Statistics", sorted_entries)

	return sorted_entries


def print_directory_section(
	directory: str,
	sort_by_time: bool,
	reverse: bool,
	show_stats: bool,
) -> tuple[bool, list[EntryInfo]]:
	print_section_header(directory)

	entries, error_message = collect_directory(directory)

	if error_message:
		print(error_message)
		return False, []

	sorted_entries = sort_entries(
		entries,
		sort_by_time,
		reverse,
	)

	if not sorted_entries:
		print("** EMPTY DIRECTORY **")

		if show_stats:
			print_report("Section Statistics", sorted_entries)

		return True, sorted_entries

	print_table(sorted_entries)

	if show_stats:
		print_report("Section Statistics", sorted_entries)

	return True, sorted_entries


def group_entries_by_parent(
	entries: list[EntryInfo],
) -> list[tuple[str, list[EntryInfo]]]:
	groups = {}

	for info in entries:
		parent = os.path.dirname(info.path)

		if not parent:
			parent = os.curdir

		parent = normalize_path(parent)

		if parent not in groups:
			groups[parent] = []

		groups[parent].append(info)

	return list(groups.items())


def main() -> int:
	parser = argparse.ArgumentParser(
		prog="dir",
		description=(
			"Display files and directories in a formatted "
			"human-oriented listing."
		),
	)

	parser.add_argument(
		"operands",
		nargs="*",
		help=(
			"files, directories, or wildcard patterns; "
			"defaults to the current directory"
		),
	)

	parser.add_argument(
		"-r",
		"--reverse",
		action="store_true",
		help="reverse the selected sort order",
	)

	parser.add_argument(
		"-t",
		"--time",
		action="store_true",
		help="sort by modification time instead of name",
	)

	parser.add_argument(
		"--stats",
		action="store_true",
		help="show statistics after each listing section",
	)

	parser.add_argument(
		"--summary",
		action="store_true",
		help="show one overall summary at the end",
	)

	args = parser.parse_args()

	overall_entries = []

	if not args.operands:
		success, displayed_entries = print_directory_section(
			os.curdir,
			args.time,
			args.reverse,
			args.stats,
		)

		overall_entries.extend(displayed_entries)

		if args.summary:
			print_report("Overall Summary", overall_entries)

		print()
		return 0 if success else 1

	expanded = expand_operands(args.operands)
	exit_code = 1 if expanded.had_error else 0

	entries = []

	for path in expanded.paths:
		info = collect_entry(path)

		if info is None:
			exit_code = 1
			continue

		entries.append(info)

	if not entries:
		if args.summary:
			print_report("Overall Summary", overall_entries)

		print()
		return 1

	plain_single_directory = (
		len(args.operands) == 1
		and not expanded.used_pattern
		and len(entries) == 1
		and entries[0].is_directory
	)

	if plain_single_directory:
		success, displayed_entries = print_directory_section(
			entries[0].path,
			args.time,
			args.reverse,
			args.stats,
		)

		overall_entries.extend(displayed_entries)

		if args.summary:
			print_report("Overall Summary", overall_entries)

		print()

		if not success:
			return 1

		return exit_code

	for parent, parent_entries in group_entries_by_parent(entries):
		displayed_entries = print_entry_section(
			parent,
			parent_entries,
			args.time,
			args.reverse,
			args.stats,
		)

		overall_entries.extend(displayed_entries)

	directories_to_expand = []
	seen_directories = set()

	for info in entries:
		if not info.is_directory:
			continue

		if info.path in seen_directories:
			continue

		seen_directories.add(info.path)
		directories_to_expand.append(info.path)

	for directory in directories_to_expand:
		success, displayed_entries = print_directory_section(
			directory,
			args.time,
			args.reverse,
			args.stats,
		)

		overall_entries.extend(displayed_entries)

		if not success:
			exit_code = 1

	if args.summary:
		print_report("Overall Summary", overall_entries)

	print()
	return exit_code


if __name__ == "__main__":
	sys.exit(main())
